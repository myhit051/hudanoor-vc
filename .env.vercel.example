# Google Sheets API Configuration
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Cloud Storage (สำหรับเก็บรูปสินค้า) — ใช้ service account ตัวเดียวกับ Sheets ได้
# ต้องเปิด GCS API และให้ service account มี Storage Object Admin บน bucket นี้
GCS_BUCKET_NAME=your-product-images-bucket

# Optional: Google OAuth (if using client-side auth)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_GOOGLE_API_KEY=your_google_api_key

# Environment
NODE_ENV=production